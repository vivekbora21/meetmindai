# Core app config
DATABASE_URL=postgresql://postgres:password@localhost:5432/meetingmind
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-this-with-a-long-random-secret

# LLM Provider configuration (supported: openrouter, ollama, openai, gemini, groq)
LLM_PROVIDER=openrouter

# OpenRouter Settings
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-2-9b-it:free

# Ollama Settings (local development fallback)
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI Settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini Settings
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq Settings
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional integrations
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadminpassword
WHISPER_MODEL_SIZE=base
PYTHON_ENV=development
SKIP_DOCKER=true
